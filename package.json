{
  "name": "niche",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "db:up": "docker compose up -d mongo",
    "db:down": "docker compose down",
    "dev": "concurrently -n web,api -c blue,green \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "vite",
    "dev:api": "npm run dev --prefix backend",
    "build": "tsc && vite build",
    "build:api": "npm run build --prefix backend",
    "preview": "vite preview"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.12"
  }
}
