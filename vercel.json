{
  "experimentalServices": {
    "frontend": {
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/api",
      "framework": "express"
    }
  },
  "rewrites": [
    {
      "source": "/spotify-embed/:path*",
      "destination": "https://open.spotify.com/embed/:path*"
    }
  ]
}
